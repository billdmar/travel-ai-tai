# Travel AI (TAI) — environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider selection: "openai" | "mock" | "langchain".
# Falls back to "mock" automatically when OPENAI_API_KEY is unset.
LLM_PROVIDER=mock
# Required only for the "openai" / "langchain" providers.
OPENAI_API_KEY=sk-your-openai-api-key-here
# Chat model used by the OpenAI / LangChain providers.
OPENAI_MODEL=gpt-4o-mini
# Hard cap on tokens per completion (cost control).
MAX_TOKENS=2000

# ── Persistence ──────────────────────────────────────────────────────────────
# SQLite by default; swap for Postgres, e.g.
#   postgresql+asyncpg://user:pass@host:5432/tai
DATABASE_URL=sqlite+aiosqlite:///./tai.db

# ── Caching ──────────────────────────────────────────────────────────────────
# "memory" (default) | "redis". Redis falls back to in-memory if unreachable.
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# ── Operations ───────────────────────────────────────────────────────────────
# Enables the /api/v1/debug/token-stats endpoint when true.
DEBUG_MODE=false
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins (Vite dev server by default).
ALLOWED_ORIGINS=http://localhost:5173
# Toggle slowapi rate limiting (10/min on POST /itineraries).
RATE_LIMIT_ENABLED=true
