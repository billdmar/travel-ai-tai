# Travel AI (TAI) — environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Provider selection: "openai" | "mock" | "langchain" | "gemini".
# Falls back to "mock" automatically when the selected provider's API key is
# unset (OPENAI_API_KEY for openai/langchain, GEMINI_API_KEY for gemini).
LLM_PROVIDER=mock
# Required only for the "openai" / "langchain" providers.
OPENAI_API_KEY=sk-your-openai-api-key-here
# Chat model used by the OpenAI / LangChain providers.
OPENAI_MODEL=gpt-4o-mini
# Required only for the "gemini" provider.
GEMINI_API_KEY=your-gemini-api-key-here
# Model used by the Gemini provider.
GEMINI_MODEL=gemini-2.0-flash
# Hard cap on tokens per completion (cost control).
MAX_TOKENS=2000

# ── Images (Unsplash proxy) ──────────────────────────────────────────────────
# Server-side Unsplash key for GET /api/v1/images. Optional: with no key the
# endpoint returns a graceful {fallback:true} envelope (the UI shows a bundled
# placeholder), so the demo works with zero configuration.
UNSPLASH_ACCESS_KEY=

# ── Affiliate tags ───────────────────────────────────────────────────────────
# Per-partner affiliate slots appended to server-owned booking links. Empty by
# default → clean plain deep links with NO tracking params (links still work,
# they just don't earn). Populate a slot to start attributing referrals.
AFFILIATE_TAG_VIATOR=
AFFILIATE_TAG_GYG=
AFFILIATE_TAG_BOOKING=
AFFILIATE_TAG_FLIGHTS=

# ── Persistence ──────────────────────────────────────────────────────────────
# SQLite by default; swap for Postgres. You can paste a hosted provider's raw
# connection string as-is — build_engine upgrades a bare postgresql:// to the
# +asyncpg driver and translates libpq-only params (sslmode, channel_binding):
#   postgresql://user:pass@ep-x.aws.neon.tech/tai?sslmode=require   (Neon raw)
#   postgresql+asyncpg://user:pass@host:5432/tai                    (explicit)
DATABASE_URL=sqlite+aiosqlite:///./tai.db

# ── Caching ──────────────────────────────────────────────────────────────────
# "memory" (default) | "redis". Redis falls back to in-memory if unreachable.
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# ── Operations ───────────────────────────────────────────────────────────────
# Enables the /api/v1/debug/token-stats endpoint when true.
DEBUG_MODE=false
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins (Vite dev server by default).
ALLOWED_ORIGINS=http://localhost:5173
# Toggle slowapi rate limiting (10/min on POST /itineraries).
RATE_LIMIT_ENABLED=true
